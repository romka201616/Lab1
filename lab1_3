/*Вариант 3
Пользователь вводит длины трех сторон треугольника. Определить его площадь и периметр.
Вывести найденные значения на экран с соответствующими пояснениями.
Пользователь вводит с клавиатуры вещественное число x.
Необходимо вычислить значение 4 / ((x-1)^2 + x) - x. 
Округлите сумму чисел y и x (x1).
Выведите значение x и y с точностью 4 знака после запятой, затем 5 символов «*», а  затем x1 все в одной строке. 
Например:x=1.0000  y=3.0000 ***** x1=4
Построить блок-схемы решения задач.
*/

#include <iostream>
#include<cmath>
using namespace std;

double square(double a, double b, double c) {
    double p = (a + b + c) / 2;
    return sqrt(p * (p - a) * (p - b) * (p - c));
}

int main()
{
    setlocale(0, "");
    double a, b, c;
    cout << "Введите длины трёх сторон треугольника:";
    cin >> a >> b >> c;
    cout << "\nПлощадь треугольника: " << square(a, b, c);
    cout << "\nПериметр треугольника: " << a + b + c;
    cout << "\n\n============================================================\n\n";

    double x, y;
    int x1;
    cout << "Введите вещественное число: ";
    cin >> x;
    y = 4 / ((x - 1) * (x - 1) + x) - x;
    x1 = round(x + y);
    cout.precision(4);
    cout << fixed << "\nx=" << x << " y=" << y << " ***** x1=" << x1;
    return 0;
}
